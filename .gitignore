.DS_Store

# Game assets & decompiled code (DO NOT COMMIT)
# No trailing slash: worktrees symlink `decompiled` to the main checkout's
# copy, and `decompiled/` (dir-only) would leave the symlink untracked-visible.
decompiled
jdk8/
_ModTheSpire/
mts-source/
lib/
ModTheSpire*.zip
game_sources/

# Reference projects (external)
reference/

# Generated annotations
annotations/

# Mod dependencies (keep src/ only)
mod/lib/
mod/target/

# Logs and temp files
logs/
*.log
tmp/

# Mod build artifacts
mod/*.jar

# Data files (large/generated)
vod_data/
data/*
# Parity oracle corpus: track action scripts + minted goldens (derived state
# snapshots for specific seeds, not source). decompiled/ stays ignored.
!data/traces/
data/traces/*
!data/traces/scripts/
!data/traces/java/

# VOD extraction outputs (generated)
vod/verify_ui/extractions.json
*_extraction.json

# Lock files (optional - uncomment to track)
# uv.lock

# Test artifacts
.coverage
htmlcov/

# Secrets
.env
*.pem
*.key
node_modules/
bun.lock
logs/
target/
.run/

# Claude Code (track config, exclude ephemeral)
.claude/worktrees/
.claude/worktree/
.claude/projects/
.claude/plans/
.claude/.credentials.env

# Model checkpoints (use GitHub Releases for curation)
checkpoints/

# Vite cache
packages/viz/.vite/

# Parity oracle corpus: track action scripts + minted goldens (derived state
# snapshots, not source). decompiled/ stays ignored.
!data/traces/
!data/traces/scripts/
!data/traces/scripts/**
!data/traces/java/
!data/traces/java/**

# Derived decompilation artifacts (regenerate: scripts/extract.sh)
reference/extracted/
